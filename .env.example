# ----------------------------------------------------------------------------
# ReliefLink — copy to `.env` and fill in (do not commit `.env`).
# ----------------------------------------------------------------------------

# MongoDB Atlas (app uses database name "relieflink" unless URI path overrides)
MONGODB_URI=mongodb+srv://user:pass@cluster0.example.mongodb.net/relieflink

# Gemini API Key
GOOGLE_GENERATIVE_AI_API_KEY=

# Shared secret for field USB bridge, local scripts, and Alexa webhooks.
# POST /api/transfer: HMAC body with this key → header `x-relieflink-signature` (hex),
# or header `x-relieflink-secret` for quick tests only.
TRANSFER_SECRET=change-me-please

# Web UI session signing (falls back to TRANSFER_SECRET if unset).
RELIEFLINK_SESSION_SECRET=

# Admin web sign-in (defaults: admin / admin). Override in production.
RELIEFLINK_ADMIN_USERNAME=
RELIEFLINK_ADMIN_PASSWORD=

# Optional: local Ollama for rare AI text translation fallbacks (optional).
# Defaults: http://127.0.0.1:11434 and llama3.2
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# Demo MongoDB users — web UI sign-in only (not env passwords). Run: pnpm seed:users
# Emails: admin@relieflink.demo | warehouse@relieflink.demo | driver@relieflink.demo
# Default password for all three: ReliefLink#2026 (set RELIEFLINK_SEED_PASSWORD to override).
RELIEFLINK_SEED_PASSWORD=

# Optional: require matching two-button PIN in JSON (`pin`, only 1 and 2).
TRANSFER_PIN=

# Milliseconds without a tap on the active leg before the batch is flagged (default 45000).
# After a tap, the delivery photo deadline is separate (2 minutes), not STALE_MS.
STALE_MS=45000

# ----------------------------------------------------------------------------
# Solana testnet — signer pays fees; B public optional counterparty in memo tx
# ----------------------------------------------------------------------------
SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_CLUSTER=testnet

WALLET_A_PUBLIC=
WALLET_A_SECRET=
WALLET_B_PUBLIC=
WALLET_B_SECRET=

# ----------------------------------------------------------------------------
# Gemini — delivery photo verification (Vercel AI SDK + @ai-sdk/google)
# Required for POST /api/driver/delivery-proof; if unset the driver app still
# works but photo uploads return 503.
# ----------------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=
# Override the model (defaults to `gemini-flash-latest`).
DELIVERY_PROOF_MODEL=

# ----------------------------------------------------------------------------
# Warehouse / store Alexa announcements
# When a shipment is dispatched with a driver, a driver taps at the dock, or
# a delivery photo is verified, the server fires a short spoken line to an
# Alexa Echo device. Voice Monkey is preferred; IFTTT Webhooks are a fallback.
# If none of these are set, announcements are silently skipped.
# ----------------------------------------------------------------------------
# VOICE_MONKEY_API_KEY = secret "token" from Voice Monkey Console → Settings →
#   API Credentials (or API Playground). Used as JSON field `token` on
#   POST https://api-v2.voicemonkey.io/announcement
# VOICE_MONKEY_DEVICE = device id string from Console → Devices (not the Alexa
#   display name). Must be a Speaker device linked to your Echo via a Routine.
#
# If Alexa says “Someone is at the …” before your message: that comes from Alexa’s
# doorbell / Smart Home behavior for the Voice Monkey virtual device, not from
# this app. In the Alexa app: review Routines tied to that device (avoid a
# second “doorbell” or generic announcement step), and check device notification
# settings. Renaming the VM device can change the spoken location phrase.
VOICE_MONKEY_API_KEY=
VOICE_MONKEY_DEVICE=alexa-echo-dot
IFTTT_WEBHOOK_KEY=
IFTTT_EVENT_NAME=relieflink_alert

# Legacy / optional tokens for the AI Voice API
VOICE_WEBHOOK_TOKEN=
VOICE_AUDIO_TOKEN=

# ElevenLabs TTS (used by /api/voice for browser audio; separate from Alexa)
ELEVENLABS_VOICE_ID= hpp4J3VqNfWAUOO0d1Us
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
ELEVENLABS_API_KEY=
