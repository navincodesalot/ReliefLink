# ----------------------------------------------------------------------------
# FoodTrust environment template. Copy to `.env` and fill in real values.
# ----------------------------------------------------------------------------

# MongoDB Atlas connection string (must include database name or default is used)
MONGODB_URI=mongodb+srv://user:pass@cluster0.example.mongodb.net/foodtrust

# Shared secret used by Raspberry Pi clients and Alexa webhooks.
# Requests to /api/transfer must send header `x-foodtrust-secret: <value>`
# AND a payload HMAC in `x-foodtrust-signature` (hex sha256 of the raw body).
TRANSFER_SECRET=change-me-please

# Optional: require the same two-button PIN from Pis and voice webhooks (string of
# 1 and 2 only, e.g. 121212). If unset, `pin` in POST bodies is not checked.
TRANSFER_PIN=

# Milliseconds without progress after which an in-transit batch is flagged.
# Short for demo (e.g. 120000 = 2 minutes).
STALE_MS=120000

# ----------------------------------------------------------------------------
# Solana (testnet). The signer address pays fees; the custody address is an
# optional counterparty we include in the memo tx to make the explorer history
# more meaningful.
# ----------------------------------------------------------------------------
SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_CLUSTER=testnet

# Two wallets from your .env — A signs/pays, B is the custody counterparty.
WALLET_A_PUBLIC=
WALLET_A_SECRET=
WALLET_B_PUBLIC=
WALLET_B_SECRET=
