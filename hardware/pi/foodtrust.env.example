# Copy to /etc/foodtrust.env on each Pi.
# Load:  set -a; source /etc/foodtrust.env; set +a; python3 transfer_button.py

API_BASE_URL=https://your-vercel-app.vercel.app
TRANSFER_SECRET=change-me-please

DEVICE_ID=pi-warehouse-01
ROLE_FROM=warehouse-1
ROLE_TO=transporter-1
BATCH_ID=batch-demo-1

# Two-button PIN: only characters 1 and 2, any length up to 32 (e.g. six digits).
# Must match TRANSFER_PIN on the Vercel server if you set it there.
TRANSFER_PIN=121212

# Seconds of no button press before a partial PIN is cleared.
PIN_IDLE_SEC=15

BUTTON_1_GPIO=17
BUTTON_2_GPIO=27
