# Full URL to the server's /api/transfer endpoint.
RELIEFLINK_API_URL=http://localhost:3000/api/transfer

# Must match the server's TRANSFER_SECRET.
TRANSFER_SECRET=change-me

# Identifier the admin binds to a shipment leg in the dashboard. This is the
# only thing that identifies the driver on the wire.
DEVICE_ID=driver-uno-01

# Serial port of the driver Arduino. On Windows: COM5. On Linux: /dev/ttyUSB0.
# Leave blank once to list available ports on startup.
SERIAL_PORT=

# Optional baud override (default 115200).
# SERIAL_BAUD=115200

# Minimum ms between accepted TAPs on the bridge side (default 1500).
# TAP_COOLDOWN_MS=1500
