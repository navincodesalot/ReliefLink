# Copy to .env in this folder. Run: pnpm start

# Full URL to POST /api/transfer
RELIEFLINK_API_URL=https://your-app.vercel.app/api/transfer

TRANSFER_SECRET=same-as-vercel
TRANSFER_PIN=121212

# Must match a row on /stations (Handoff stations UI)
DEVICE_ID=field-uno-01

# Windows: COM3 — omit once to list ports
SERIAL_PORT=COM3
SERIAL_BAUD=115200

PIN_IDLE_MS=15000

# Re-fetch assignment from UI for LCD / before PIN (ms)
ASSIGNMENT_POLL_MS=8000
