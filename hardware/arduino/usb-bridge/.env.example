# Full URL to the server's /api/transfer endpoint.
RELIEFLINK_API_URL=http://localhost:3000/api/transfer

# Must match the server's TRANSFER_SECRET.
TRANSFER_SECRET=change-me

# Store Arduino (USB): device id comes from RELIEFLINK_STORE_READY / RELIEFLINK_TAP
# on the serial port — no DEVICE_ID required. Optional legacy fallback: if the
# board only sends a bare `TAP` line, set DEVICE_ID here for /api/transfer.
# DEVICE_ID=

# Serial port of the store Arduino. On Windows: COM5. On Linux: /dev/ttyUSB0.
# Leave blank once to list available ports on startup.
SERIAL_PORT=

# Optional baud override (default 115200; must match store_beacon.ino).
# SERIAL_BAUD=115200

# Minimum ms between accepted TAPs on the bridge side (default 1500).
# TAP_COOLDOWN_MS=1500
